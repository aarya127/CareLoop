    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/throttler": "^6.2.1",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "bcrypt": "^6.0.0",

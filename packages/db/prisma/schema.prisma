// Prisma schema for CareLoop
// Multi-tenant dental practice management with availability computation
// Set DATABASE_URL in .env to your Postgres connection string

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// MULTI-TENANCY: Practice (root entity for all data)
// ============================================================================

model Practice {
  id                String                    @id @default(cuid())
  name              String
  address           String?
  timeZone          String                    @default("America/New_York")
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  users             User[]
  patients          Patient[]
  appointments      Appointment[]
  providers         Provider[]
  rooms             Room[]
  providerSchedules ProviderSchedule[]
  availabilityBlocks AvailabilityBlock[]
  appointmentHolds  AppointmentHold[]
  googleConnections GoogleCalendarConnection[]
  callTranscripts   CallTranscript[]
  practiceKpis      PracticeKPI[]
  conversations     Conversation[]
  promptVersions    AIPromptVersion[]
  alertThresholds   AlertThreshold[]
  routingPolicies   RoutingPolicy[]
  intakeSubmissions IntakeSubmission[]
  intakeDrafts      IntakeDraft[]
  treatmentRecords  TreatmentRecord[]
  invoices          Invoice[]
  payments          PaymentRecord[]
  documents         Document[]
  reminders         Reminder[]
  sensitiveNotes    PatientSensitiveNote[]
  encounters        Encounter[]
  allergies         Allergy[]
  medications       Medication[]
  conditions        Condition[]
  toothChartEntries ToothChartEntry[]
  periodontalExams  PeriodontalExam[]
  treatmentPlans    TreatmentPlan[]
  invitations       Invitation[]
  claims            Claim[]

  @@index([name])
}

/// Team invitations — an admin/manager invites someone by email to join their
/// practice with a given role. The raw token lives only in the invite link; we
/// store its SHA-256 hash (same approach as Session). Accepting creates the User.
model Invitation {
  id              String    @id @default(cuid())
  practiceId      String
  email           String
  role            String    @default("staff")
  tokenHash       String    @unique
  status          String    @default("pending") // pending | accepted | revoked | expired
  invitedByUserId String?
  acceptedUserId  String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  practice        Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, status])
  @@index([email])
}

/// Insurance claim submitted to a payer for a patient's treatment. Tracks the
/// adjudication lifecycle (draft → submitted → accepted/rejected/paid) with a
/// full status-event trail and rejection codes.
model Claim {
  id                  String   @id @default(cuid())
  practiceId          String
  patientId           String
  insuranceId         String?  // PatientInsurance used (soft ref — no FK)
  treatmentId         String?
  invoiceId           String?
  claimNumber         String?  // external payer/clearinghouse claim number
  status              String   @default("draft") // draft|submitted|accepted|rejected|paid|void
  totalChargedCents   Int      @default(0)
  approvedAmountCents Int?
  rejectionCode       String?
  notes               String?
  submittedAt         DateTime?
  resolvedAt          DateTime?
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  practice Practice           @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  lines    ClaimLine[]
  events   ClaimStatusEvent[]

  @@index([practiceId, status])
  @@index([patientId])
}

model ClaimLine {
  id            String   @id @default(cuid())
  claimId       String
  procedureCode String
  description   String?
  toothNumber   Int?
  chargedCents  Int      @default(0)
  allowedCents  Int?
  createdAt     DateTime @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

model ClaimStatusEvent {
  id          String   @id @default(cuid())
  claimId     String
  status      String
  code        String?  // rejection / adjudication code
  note        String?
  actorUserId String?
  createdAt   DateTime @default(now())

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId, createdAt])
}

// ============================================================================
// USER & AUTH (scoped to Practice)
// ============================================================================

model User {
  id                 String                     @id @default(cuid())
  email              String                     @unique
  practiceId         String
  firstName          String?
  lastName           String?
  passwordHash       String?
  passwordAlgo       String                     @default("bcrypt")
  emailVerifiedAt    DateTime?
  status             String                     @default("active")
  failedLoginCount   Int                        @default(0)
  lockedUntil        DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  deletedAt          DateTime?
  deletedReason      String?
  calendars          GoogleCalendarConnection[]
  appointments       Appointment[]
  participants       Participant[]
  roles              UserRole[]
  sessions           Session[]
  authIdentities     AuthIdentity[]
  assignedRoles      UserRole[]                 @relation("RoleAssignedBy")
  auditActorEntries  AuditLog[]                 @relation("AuditActorUser")
  auditTargetEntries AuditLog[]                 @relation("AuditTargetUser")
  uploadedDocuments  Document[]
  sensitiveNotes     PatientSensitiveNote[]

  practice           Practice                   @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([status, lockedUntil])
}

model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       UserRole[]
}

model UserRole {
  userId     String
  roleId     Int
  assignedBy String?
  assignedAt DateTime @default(now())

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedByUser User? @relation("RoleAssignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@index([roleId])
}

model Session {
  id                 String    @id @default(cuid())
  userId             String
  sessionTokenHash   String    @unique
  csrfSecretHash     String
  createdAt          DateTime  @default(now())
  lastSeenAt         DateTime  @default(now())
  expiresAt          DateTime
  idleExpiresAt      DateTime
  rotatedAt          DateTime?
  revokedAt          DateTime?
  revokeReason       String?
  createdByIp        String?
  createdByUserAgentHash String?

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs  AuditLog[]

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([idleExpiresAt])
}

model ServiceAccount {
  id               String    @id @default(cuid())
  name             String
  clientId         String    @unique
  clientSecretHash String
  status           String    @default("active")
  scopes           String[]  @default([])
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  rotatedAt        DateTime?
  revokedAt        DateTime?

  auditLogs AuditLog[]
}

model AuditLog {
  id                   BigInt   @id @default(autoincrement())
  eventTime            DateTime @default(now())
  actorUserId          String?
  actorServiceAccountId String?
  eventType            String
  authMethod           String?
  outcome              String
  targetUserId         String?
  sessionId            String?
  ip                   String?
  userAgentHash        String?
  requestId            String?
  metadata             Json     @default("{}")

  actorUser           User?            @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorServiceAccount ServiceAccount?  @relation(fields: [actorServiceAccountId], references: [id], onDelete: SetNull)
  targetUser          User?            @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  session             Session?         @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([eventTime])
  @@index([eventType, eventTime])
  @@index([actorUserId, eventTime])
  @@index([targetUserId, eventTime])
}

model AuthIdentity {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerSubject   String
  providerEmail     String?
  providerEmailVerified Boolean @default(false)
  linkedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([userId])
}

// ============================================================================
// PATIENTS & INSURANCE (scoped to Practice)
// ============================================================================

model Patient {
  id          String   @id @default(cuid())
  practiceId  String
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  phoneE164   String?
  patientType String   @default("existing")
  gender      String?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practice         Practice             @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  insuranceRecords PatientInsurance[]
  transcripts      CallTranscript[]
  participants     Participant[]
  intakeSubmissions IntakeSubmission[]
  intakeDrafts      IntakeDraft[]
  treatmentRecords  TreatmentRecord[]
  invoices          Invoice[]
  payments          PaymentRecord[]
  documents         Document[]
  reminders         Reminder[]
  sensitiveNotes    PatientSensitiveNote[]
  encounters        Encounter[]
  allergies         Allergy[]
  medications       Medication[]
  conditions        Condition[]
  toothChartEntries ToothChartEntry[]
  periodontalExams  PeriodontalExam[]
  treatmentPlans    TreatmentPlan[]
  claims            Claim[]

  @@index([practiceId, lastName, firstName])
  @@unique([practiceId, phoneE164])
}

model PatientInsurance {
  id              String   @id @default(cuid())
  patientId       String
  payerName       String
  planName        String?
  memberIdEnc     String
  memberIdHash    String?  // SHA-256 of raw member ID for indexed lookup
  groupNumberEnc  String?
  coverageSummary Json?
  active          Boolean  @default(true)
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, active])
  @@index([memberIdHash])
}

// ============================================================================
// PROVIDERS & ROOMS (scoped to Practice)
// ============================================================================

model Provider {
  id        String   @id @default(cuid())
  practiceId String
  name      String
  license   String?
  specialty String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practice         Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  schedules        ProviderSchedule[]
  availabilityBlocks AvailabilityBlock[]
  holds            AppointmentHold[]
  treatmentRecords TreatmentRecord[]

  @@unique([practiceId, name])
  @@index([practiceId, isActive])
}

model Room {
  id        String   @id @default(cuid())
  practiceId String
  name      String
  capacity  Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practice            Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  appointments        Appointment[]
  availabilityBlocks  AvailabilityBlock[]
  appointmentHolds    AppointmentHold[]

  @@unique([practiceId, name])
  @@index([practiceId, isActive])
}

// ============================================================================
// APPOINTMENTS (scoped to Practice)
// ============================================================================

model Appointment {
  id            String            @id @default(cuid())
  practiceId    String
  userId        String
  providerId    String
  roomId        String?
  title         String
  notes         String?
  start         DateTime
  end           DateTime
  timeZone      String            @default("America/New_York")
  patientId     String?
  procedureCode String?
  googleEventId String?
  calendarId    String?
  status        String            @default("confirmed")
  source        String            @default("manual")
  createdBy     String            @default("system")
  extended      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  practice        Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        Provider  @relation(fields: [providerId], references: [id], onDelete: Restrict)
  room            Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  callTranscripts CallTranscript[]
  reminders       Reminder[]

  @@index([practiceId, patientId, start])
  @@index([practiceId, userId, start])
  @@index([practiceId, providerId, start])
  @@unique([practiceId, calendarId, googleEventId])
}

// ============================================================================
// GOOGLE CALENDAR INTEGRATION (scoped to Practice)
// ============================================================================

model GoogleCalendarConnection {
  id             String   @id @default(cuid())
  practiceId     String
  userId         String
  provider       String   @default("google")
  calendarId     String
  accessToken    String
  refreshToken   String
  tokenExpiry    DateTime
  syncToken      String?
  resourceId     String?
  channelId      String?
  channelExpiry  DateTime?
  timeZone       String
  color          String?

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([practiceId, userId, provider, calendarId])
  @@index([practiceId])
}

// ============================================================================
// AVAILABILITY MODELS (scoped to Practice)
// ============================================================================

model ProviderSchedule {
  id         String   @id @default(cuid())
  practiceId String
  providerId String
  dayOfWeek  Int
  startMin   Int
  endMin     Int
  effectiveFrom DateTime?
  effectiveTo DateTime?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider  Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, dayOfWeek, startMin, endMin, effectiveFrom])
  @@index([practiceId, providerId])
  @@index([providerId, dayOfWeek])
}

model AvailabilityBlock {
  id         String   @id @default(cuid())
  practiceId String
  providerId String?
  roomId     String?
  start      DateTime
  end        DateTime
  reason     String
  source     String   @default("manual")
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  practice  Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider  Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)
  room      Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([practiceId, start, end])
  @@index([providerId, start, end])
  @@index([roomId, start, end])
}

model AppointmentHold {
  id         String   @id @default(cuid())
  practiceId String
  providerId String?
  roomId     String?
  start      DateTime
  end        DateTime
  patientId  String?
  expiresAt  DateTime
  createdBy  String
  reason     String?
  createdAt  DateTime @default(now())

  practice  Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  provider  Provider? @relation(fields: [providerId], references: [id], onDelete: Cascade)
  room      Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([practiceId, start, end, expiresAt])
  @@index([providerId, start, end])
}

// ============================================================================
// CALLS & TRANSCRIPTS (scoped to Practice)
// ============================================================================

model CallTranscript {
  id                  String   @id @default(cuid())
  practiceId          String
  patientId           String?
  appointmentId       String?
  callSid             String   @unique
  orchestrator        String
  startedAt           DateTime
  endedAt             DateTime?
  fullTranscript      String?
  transcriptEmbedding String?
  sentimentScore      Float?
  treatmentAcceptance Boolean?
  handoffOccurred     Boolean  @default(false)
  createdAt           DateTime @default(now())

  practice     Practice              @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient      Patient?              @relation(fields: [patientId], references: [id], onDelete: SetNull)
  appointment  Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  segments     CallTranscriptSegment[]
  analytics    AnalyticsResult?
  kpiRows      PracticeKPI[]

  @@index([practiceId, patientId, createdAt])
  @@index([practiceId, appointmentId])
}

model CallTranscriptSegment {
  id           Int      @id @default(autoincrement())
  transcriptId String
  speaker      String
  text         String
  startedAt    DateTime
  endedAt      DateTime?
  confidence   Float?
  meta         Json?

  transcript CallTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)

  @@index([transcriptId, startedAt])
}

// ============================================================================
// ANALYTICS (scoped to Practice)
// ============================================================================

model AnalyticsResult {
  id                     String   @id @default(cuid())
  transcriptId           String   @unique
  sentimentScore         Int
  satisfactionByProvider Json
  treatmentAcceptance    Json
  riskFlags              Json     @default("[]")
  generatedAt            DateTime @default(now())

  transcript CallTranscript @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
}

model PracticeKPI {
  id           Int      @id @default(autoincrement())
  practiceId   String
  kpiDate      DateTime
  metricName   String
  metricValue  Float
  dimensions   Json?
  transcriptId String?
  createdAt    DateTime @default(now())

  practice   Practice       @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  transcript CallTranscript? @relation(fields: [transcriptId], references: [id], onDelete: SetNull)

  @@index([practiceId, kpiDate])
  @@index([metricName, kpiDate])
}

// ============================================================================
// AI & ROUTING (scoped to Practice)
// ============================================================================

model AIPromptVersion {
  id           String   @id @default(cuid())
  practiceId   String
  version      Int
  systemPrompt String
  isActive     Boolean  @default(false)
  createdBy    String?
  createdAt    DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([practiceId, version])
  @@index([practiceId, isActive])
}

model AlertThreshold {
  id                         String   @id @default(cuid())
  practiceId                 String   @unique
  sentimentMin               Int      @default(4)
  escalateOnTreatmentDecline Boolean  @default(true)
  notifyChannel              Json?
  updatedAt                  DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model RoutingPolicy {
  id          String   @id @default(cuid())
  practiceId  String
  patientType String
  mode        String
  updatedAt   DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([practiceId, patientType])
}

// ============================================================================
// MESSAGING (scoped to Practice) - FUTURE
// ============================================================================

model Conversation {
  id         String   @id @default(cuid())
  practiceId String
  participants Participant[]
  messages   Message[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId, updatedAt])
}

model Participant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String?
  patientId      String?
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  patient      Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([conversationId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  sentAt         DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt])
}

// ============================================================================
// INTAKE SUBMISSIONS
// ============================================================================

model IntakeSubmission {
  id          String    @id @default(cuid())
  practiceId  String
  patientId   String?
  formType    String    // "new_patient", "medical_history", "consent", etc.
  status      String    @default("pending") // pending, reviewed, archived
  data        Json      // raw form fields
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([practiceId, status, submittedAt])
  @@index([patientId, submittedAt])
}

// ============================================================================
// INTAKE DRAFTS (pre-submission form state)
// ============================================================================

model IntakeDraft {
  id             String    @id @default(cuid())
  practiceId     String
  token          String    @unique @default(cuid())
  status         String    @default("draft") // draft | submitted
  data           Json      @default("{}")
  patientId      String?
  idempotencyKey String?   @unique
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  @@index([practiceId, status])
  @@index([token])
}

// ============================================================================
// TREATMENT RECORDS
// ============================================================================

model TreatmentRecord {
  id            String    @id @default(cuid())
  practiceId    String
  patientId     String
  appointmentId String?
  providerId    String?
  procedureCode String?
  toothNumber   Int?
  surface       String?
  notes         String?
  status        String    @default("planned") // planned, in_progress, completed, cancelled
  completedAt   DateTime?
  createdBy     String?   // userId of the clinician who created this record
  updatedBy     String?   // userId of the last person to update this record
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  practice    Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  provider    Provider?    @relation(fields: [providerId], references: [id], onDelete: SetNull)
  invoice     Invoice?

  @@index([practiceId, patientId, createdAt])
  @@index([practiceId, status, createdAt])
  @@index([patientId, procedureCode])
}

// ============================================================================
// INVOICES
// ============================================================================

model Invoice {
  id               String    @id @default(cuid())
  practiceId       String
  patientId        String
  treatmentId      String?   @unique
  payerType        String    @default("patient") // patient | insurance
  status           String    @default("draft") // draft, sent, paid, overdue, void
  totalAmountCents Int
  lineItems        Json?     // [{ description, procedureCode?, qty, unitPriceCents }]
  notes            String?
  dueDate          DateTime?
  issuedAt         DateTime?
  paidAt           DateTime?
  createdBy        String?
  updatedBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  practice  Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient   Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  treatment TreatmentRecord? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  payments  PaymentRecord[]

  @@index([practiceId, patientId, createdAt])
  @@index([practiceId, status, dueDate])
}

// ============================================================================
// PAYMENT RECORDS
// ============================================================================

model PaymentRecord {
  id             String    @id @default(cuid())
  practiceId     String
  invoiceId      String
  patientId      String
  payerType      String    @default("patient") // patient | insurance
  method         String    // card | cash | insurance | check | ach
  amountCents    Int
  status         String    @default("pending") // pending, completed, refunded, failed
  transactionRef String?
  createdBy      String?
  paidAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  invoice  Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, createdAt])
  @@index([practiceId, status, createdAt])
  @@index([invoiceId])
}

// ============================================================================
// DOCUMENTS
// ============================================================================

// Document categories (removed 'xray' category)
enum DocumentCategory {
  consent
  insurance_card
  lab_report
  referral
  other
  radiograph
  clinical_photo
  treatment_plan
}

model Document {
  id               String   @id @default(cuid())
  practiceId       String
  patientId        String?
  uploadedBy       String?
  category         DocumentCategory
  fileName         String
  mimeType         String
  storageKey       String   // S3 key — never expose directly
  sizeBytes        Int?
  checksumSha256   String?  // hex SHA-256 of file bytes, client-supplied
  status           String   @default("uploading") // uploading, active, deleted
  uploadedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  uploader User?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([practiceId, patientId, uploadedAt])
  @@index([practiceId, category, uploadedAt])
  @@index([practiceId, uploadedAt])
}

// ============================================================================
// REMINDERS
// ============================================================================

model Reminder {
  id            String    @id @default(cuid())
  practiceId    String
  patientId     String
  appointmentId String?
  channel       String    // "sms" | "email" | "push"
  type          String    // "appointment_reminder" | "recall" | "payment_due"
  status        String    @default("pending") // pending, sent, failed, cancelled
  scheduledAt   DateTime
  sentAt        DateTime?
  failReason    String?
  retryCount    Int       @default(0)
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  practice    Practice     @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([practiceId, status, scheduledAt])
  @@index([patientId, scheduledAt])
  @@index([appointmentId])
}

// ============================================================================
// WEBHOOK INBOUND EVENT LOG
// idempotencyKey is unique — ensures each inbound webhook is processed once.
// ============================================================================

model WebhookLog {
  id             String    @id @default(cuid())
  provider       String    // twilio | sendgrid | google_calendar | stripe
  event          String    // e.g. "inbound_sms", "delivered", "calendar_push"
  idempotencyKey String    @unique // provider-scoped dedup key
  rawPayload     Json      @default("{}")
  status         String    @default("received") // received | processed | failed | duplicate
  processedAt    DateTime?
  error          String?
  createdAt      DateTime  @default(now())

  @@index([provider, event, createdAt])
}

// ============================================================================
// DEAD-LETTER / FAILED JOBS
// Written by the worker failed event handler after all BullMQ retries exhausted.
// ============================================================================

model FailedJob {
  id           String    @id @default(cuid())
  queue        String
  jobId        String
  jobName      String
  data         Json      @default("{}")
  failReason   String
  attemptsMade Int       @default(0)
  practiceId   String?
  failedAt     DateTime  @default(now())
  retriedAt    DateTime?

  @@index([queue, failedAt])
  @@index([practiceId, failedAt])
}

// ============================================================================
// PATIENT SENSITIVE NOTES (vertical partition — separate from Patient core)
// Access requires elevated permission; audited on every read/write.
// ============================================================================

model PatientSensitiveNote {
  id         String   @id @default(cuid())
  practiceId String
  patientId  String
  authorId   String?
  noteType   String   @default("clinical") // clinical, social, administrative
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  author   User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([practiceId, patientId, createdAt])
}

// ============================================================================
// EMR — Electronic Medical Record (first-class clinical models)
// User references (authorId, recordedBy, ...) are plain String ids, following
// the TreatmentRecord.createdBy convention, to avoid User back-relation sprawl.
// ============================================================================

model Encounter {
  id             String   @id @default(cuid())
  practiceId     String
  patientId      String
  appointmentId  String?
  providerId     String?
  authorId       String?  // clinician (User id) who wrote the note
  encounterDate  DateTime @default(now())
  type           String   @default("exam") // exam, cleaning, consult, procedure, followup
  chiefComplaint String?
  subjective     String?  // SOAP: S
  objective      String?  // SOAP: O
  assessment     String?  // SOAP: A
  plan           String?  // SOAP: P
  status         String   @default("draft") // draft, signed, amended
  signedAt       DateTime?
  signedBy       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, encounterDate])
  @@index([practiceId, status, encounterDate])
}

model Allergy {
  id         String   @id @default(cuid())
  practiceId String
  patientId  String
  allergen   String
  severity   String   @default("moderate") // mild, moderate, severe, life_threatening
  reaction   String?
  status     String   @default("active") // active, inactive
  recordedBy String?
  notedAt    DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, status])
}

model Medication {
  id           String    @id @default(cuid())
  practiceId   String
  patientId    String
  name         String
  dosage       String?
  frequency    String?
  route        String?
  status       String    @default("active") // active, discontinued
  startDate    DateTime?
  endDate      DateTime?
  prescribedBy String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, status])
}

model Condition {
  id           String    @id @default(cuid())
  practiceId   String
  patientId    String
  name         String
  code         String?   // optional ICD/SNOMED code
  status       String    @default("active") // active, resolved, chronic
  onsetDate    DateTime?
  resolvedDate DateTime?
  notes        String?
  recordedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, status])
}

model ToothChartEntry {
  id          String   @id @default(cuid())
  practiceId  String
  patientId   String
  toothNumber Int      // Universal numbering 1-32
  surfaces    String[] // mesial, distal, occlusal, buccal, lingual
  condition   String   // caries, filling, crown, missing, implant, ...
  status      String   @default("active") // active, planned, resolved
  notes       String?
  chartedBy   String?
  chartedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([practiceId, patientId, toothNumber])
  @@index([practiceId, patientId])
}

model PeriodontalExam {
  id           String   @id @default(cuid())
  practiceId   String
  patientId    String
  examDate     DateTime @default(now())
  examinedBy   String?
  // Per-tooth-site measurements (pocket depth, recession, bleeding, mobility).
  // Stored as JSON to keep whole-chart load lightweight; promote to a child
  // table if per-site querying/trending is later required.
  measurements Json?
  summary      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([practiceId, patientId, examDate])
}

// ============================================================================
// TREATMENT PLANS (grouped planned procedures with estimate + acceptance)
// ============================================================================

model TreatmentPlan {
  id                     String    @id @default(cuid())
  practiceId             String
  patientId              String
  providerId             String?
  title                  String    @default("Treatment Plan")
  status                 String    @default("draft") // draft, proposed, accepted, completed, cancelled
  estimatedCostCents     Int       @default(0)
  insuranceEstimateCents Int       @default(0)
  notes                  String?
  acceptedAt             DateTime?
  acceptedBy             String?
  createdBy              String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  practice Practice            @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  patient  Patient             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  items    TreatmentPlanItem[]

  @@index([practiceId, patientId, createdAt])
  @@index([practiceId, status])
}

model TreatmentPlanItem {
  id            String   @id @default(cuid())
  planId        String
  toothNumber   Int?
  surface       String?
  procedureCode String?
  description   String
  feeCents      Int      @default(0)
  status        String   @default("planned") // planned, approved, completed, declined
  sortOrder     Int      @default(0)
  treatmentRecordId String?  // set when completed → linked TreatmentRecord
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  plan TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}

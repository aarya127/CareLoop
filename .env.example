# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:3001

# Authentication
JWT_SECRET=your-secret-key-here

# Vercel Analytics (optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Feature Flags
# NEXT_PUBLIC_ENABLE_SMART_FILL=true
# NEXT_PUBLIC_ENABLE_RESOURCE_TIMELINE=true
# NEXT_PUBLIC_ENABLE_LIVE_CALL_TILES=true

# Optional external dataset (image folder)
# DENTAL_REC_DIR="/Users/<you>/Desktop/dental rec"

# Google Calendar Integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback
APP_BASE_URL=http://localhost:3000
ENCRYPTION_KEY=use-a-long-random-string-here

# Database (Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/careloop?schema=public

# Demo auth fallback
DEMO_USER_ID=demo-user
